// ─── Step 1: Select Service ───────────────────────────────────────────────────

function StepSelectService({
  services,
  isLoading,
  selected,
  onSelect,
}: {
  services: Service[] | undefined;
  isLoading: boolean;
  selected: Service | null;
  onSelect: (s: Service) => void;
}) {
  const [search, setSearch] = useState("");

  const activeServices = useMemo(
    () => services?.filter((s) => s.isActive) ?? [],
    [services],
  );

  const filtered = useMemo(() => {
    if (!search.trim()) return activeServices;
    return activeServices.filter(
      (s) =>
        s.name.toLowerCase().includes(search.toLowerCase()) ||
        s.category.toLowerCase().includes(search.toLowerCase()),
    );
  }, [activeServices, search]);

  const categories = useMemo(
    () => [...new Set(filtered.map((s) => s.category))],
    [filtered],
  );

  return (
    <div className="space-y-5 animate-fade-in">
      <div>
        <h2 className="font-display text-2xl font-bold text-foreground mb-1">
          Select a Service
        </h2>
        <p className="text-muted-foreground text-sm">
          Choose the diagnostic service you need.
        </p>
      </div>

      {/* Search */}
      <div className="relative">
        <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground" />
        <Input
          placeholder="Search services..."
          value={search}
          onChange={(e) => setSearch(e.target.value)}
          className="pl-9 rounded-xl h-11"
          data-ocid="service-search-input"
        />
      </div>

      {/* Service grid */}
      {isLoading ? (
        <div className="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {["s1", "s2", "s3", "s4", "s5", "s6"].map((k) => (
            <Skeleton key={k} className="h-20 rounded-xl" />
          ))}
        </div>
      ) : (
        <div className="space-y-5 max-h-[420px] overflow-y-auto pr-1">
          {categories.map((cat) => (
            <div key={cat}>
              <p className="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-2 px-1">
                {cat}
              </p>
              <div className="grid grid-cols-1 sm:grid-cols-2 gap-2.5">
                {filtered
                  .filter((s) => s.category === cat)
                  .map((service) => {
                    const isSelected = selected?.name === service.name;
                    return (
                      <button
                        type="button"
                        key={service.name}
                        onClick={() => onSelect(service)}
                        data-ocid={`service-card-${service.name.replace(/\s+/g, "-").toLowerCase()}`}
                        className={`relative text-left p-4 rounded-xl border-2 transition-all duration-200 ${
                          isSelected
                            ? "border-primary bg-primary/8 shadow-medical"
                            : "border-border hover:border-primary/40 hover:bg-secondary/50"
                        }`}
                      >
                        {isSelected && (
                          <CheckCircle2 className="absolute top-3 right-3 w-4 h-4 text-primary" />
                        )}
                        <p className="font-semibold text-foreground text-sm pr-5">
                          {service.name}
                        </p>
                        {service.description && (
                          <p className="text-xs text-muted-foreground mt-0.5 line-clamp-1">
                            {service.description}
                          </p>
                        )}
                      </button>
                    );
                  })}
              </div>
            </div>
          ))}
          {filtered.length === 0 && (
            <div className="text-center py-10 text-muted-foreground text-sm">
              No services found for "{search}"
            </div>
          )}
        </div>
      )}

      {/* Selected preview */}
      {selected && (
        <div className="flex items-start gap-3 p-4 bg-primary/6 rounded-xl border border-primary/15 animate-fade-in">
          <CheckCircle2 className="w-5 h-5 text-primary mt-0.5 flex-shrink-0" />
          <div>
            <p className="text-sm font-semibold text-primary">
              {selected.name}
            </p>
            {selected.preparation && selected.preparation !== "None" && (
              <p className="text-xs text-muted-foreground mt-1">
                <strong>Prep:</strong> {selected.preparation}
              </p>
            )}
          </div>
        </div>
      )}
    </div>
  );
}

// ─── Step 2: Choose Doctor ────────────────────────────────────────────────────

function StepChooseDoctor({
  doctors,
  isLoading,
  selected,
  onSelect,
}: {
  doctors: Doctor[] | undefined;
  isLoading: boolean;
  selected: Doctor | null;
  onSelect: (d: Doctor) => void;
}) {
  const activeDoctors = useMemo(
    () => doctors?.filter((d) => !d.isPlaceholder && d.isActive) ?? [],
    [doctors],
  );

  return (
    <div className="space-y-5 animate-fade-in">
      <div>
        <h2 className="font-display text-2xl font-bold text-foreground mb-1">
          Choose Your Doctor
        </h2>
        <p className="text-muted-foreground text-sm">
          Select from our team of experienced radiologists.
        </p>
      </div>

      {isLoading ? (
        <div className="space-y-3">
          {["d1", "d2"].map((k) => (
            <Skeleton key={k} className="h-28 rounded-xl" />
          ))}
        </div>
      ) : (
        <div className="space-y-3">
          {activeDoctors.map((doctor) => {
            const isSelected = selected?.name === doctor.name;
            const imgSrc = doctor.name.includes("Humera")
              ? "/assets/generated/doctor-humera.dim_300x300.png"
              : "/assets/generated/doctor-naved.dim_300x300.png";

            return (
              <button
                type="button"
                key={doctor.name}
                onClick={() => onSelect(doctor)}
                data-ocid={`doctor-card-${doctor.name.replace(/\s+/g, "-").toLowerCase()}`}
                className={`w-full text-left p-5 rounded-xl border-2 transition-all duration-200 ${
                  isSelected
                    ? "border-primary bg-primary/6 shadow-medical"
                    : "border-border hover:border-primary/40 hover:bg-secondary/40"
                }`}
              >
                <div className="flex items-center gap-4">
                  <img
                    src={imgSrc}
                    alt={doctor.name}
                    className={`w-16 h-16 rounded-full object-cover border-2 transition-all ${
                      isSelected ? "border-primary" : "border-border"
                    }`}
                  />
                  <div className="flex-1 min-w-0">
                    <div className="flex items-start justify-between gap-2">
                      <div>
                        <p className="font-display font-bold text-foreground text-base">
                          {doctor.name}
                        </p>
                        <p className="text-sm text-primary font-medium">
                          {doctor.qualifications}
                        </p>
                        <p className="text-xs text-muted-foreground mt-0.5">
                          {doctor.specialization} · {Number(doctor.experience)}+
                          yrs exp
                        </p>
                      </div>
                      {isSelected && (
                        <CheckCircle2 className="w-5 h-5 text-primary flex-shrink-0 mt-0.5" />
                      )}
                    </div>
                    <div className="flex items-center gap-1.5 mt-2">
                      <div className="flex items-center gap-1 bg-primary/10 text-primary rounded-full px-2.5 py-0.5 text-xs font-medium">
                        <Clock className="w-3 h-3" />
                        <span>
                          {doctor.timingStart} – {doctor.timingEnd}
                        </span>
                      </div>
                    </div>
                  </div>
                </div>
              </button>
            );
          })}
        </div>
      )}
    </div>
  );
}

// ─── Step 3: Date & Time ──────────────────────────────────────────────────────

function StepDateTime({
  doctor,
  date,
  time,
  onDateChange,
  onTimeChange,
}: {
  doctor: Doctor | null;
  date: string;
  time: string;
  onDateChange: (d: string) => void;
  onTimeChange: (t: string) => void;
}) {
  const today = new Date().toISOString().split("T")[0];
  const slots = doctor ? getSlotsForDoctor(doctor) : [];

  return (
    <div className="space-y-6 animate-fade-in">
      <div>
        <h2 className="font-display text-2xl font-bold text-foreground mb-1">
          Pick Date & Time
        </h2>
        <p className="text-muted-foreground text-sm">
          Choose your preferred appointment date and time slot.
        </p>
      </div>

      {/* Date picker */}
      <div className="space-y-2">
        <Label htmlFor="appt-date" className="font-semibold text-sm">
          Preferred Date <span className="text-destructive">*</span>
        </Label>
        <Input
          id="appt-date"
          type="date"
          value={date}
          onChange={(e) => onDateChange(e.target.value)}
          min={today}
          className="rounded-xl h-12 font-body"
          data-ocid="date-picker-input"
        />
      </div>

      {/* Time slots */}
      {date && doctor && (
        <div className="space-y-3 animate-fade-in">
          <Label className="font-semibold text-sm">
            Available Time Slots{" "}
            <span className="text-muted-foreground font-normal">
              ({doctor.timingStart} – {doctor.timingEnd})
            </span>
          </Label>
          <div className="flex flex-wrap gap-2" data-ocid="time-slots-grid">
            {slots.map((slot) => {
              const isSelected = time === slot;
              return (
                <button
                  type="button"
                  key={slot}
                  onClick={() => onTimeChange(slot)}
                  data-ocid={`time-slot-${slot.replace(/\s+/g, "-").toLowerCase()}`}
                  className={`px-3.5 py-2 rounded-xl text-sm font-medium border-2 transition-all duration-150 ${
                    isSelected
                      ? "bg-primary text-primary-foreground border-primary shadow-medical"
                      : "bg-card border-border text-foreground hover:border-primary/50 hover:bg-primary/6"
                  }`}
                >
                  {slot}
                </button>
              );
            })}
          </div>
        </div>
      )}

      {!date && (
        <p className="text-sm text-muted-foreground italic">
          Please select a date first to view available time slots.
        </p>
      )}

      {/* Info note */}
      <div className="flex items-start gap-2.5 p-3.5 bg-secondary rounded-xl border border-border text-xs text-muted-foreground">
        <Clock className="w-4 h-4 text-primary flex-shrink-0 mt-0.5" />
        <span>
          Your appointment request will be reviewed by our admin. You'll receive
          confirmation within 24 hours.
        </span>
      </div>
    </div>
  );
}

// ─── Step 4: Confirm ──────────────────────────────────────────────────────────

function StepConfirm({
  state,
  notes,
  onNotesChange,
  onSubmit,
  isPending,
}: {
  state: WizardState;
  notes: string;
  onNotesChange: (v: string) => void;
  onSubmit: () => void;
  isPending: boolean;
}) {
  const summaryRows = [
    { label: "Service", value: state.selectedService?.name ?? "—" },
    { label: "Doctor", value: state.selectedDoctor?.name ?? "—" },
    { label: "Date", value: state.preferredDate },
    { label: "Time", value: state.preferredTime },
  ];

  return (
    <div className="space-y-6 animate-fade-in">
      <div>
        <h2 className="font-display text-2xl font-bold text-foreground mb-1">
          Review & Confirm
        </h2>
        <p className="text-muted-foreground text-sm">
          Double-check your details before confirming.
        </p>
      </div>

      {/* Summary card */}
      <div className="bg-secondary/60 rounded-2xl border border-border overflow-hidden">
        {summaryRows.map((row, i) => (
          <div
            key={row.label}
            className={`flex items-center justify-between px-5 py-3.5 ${
              i < summaryRows.length - 1 ? "border-b border-border" : ""
            }`}
          >
            <span className="text-sm text-muted-foreground font-medium">
              {row.label}
            </span>
            <span className="text-sm font-semibold text-foreground text-right max-w-[60%]">
              {row.value}
            </span>
          </div>
        ))}
      </div>

      {/* Notes */}
      <div className="space-y-2">
        <Label htmlFor="appt-notes" className="font-semibold text-sm">
          Special Requests / Notes{" "}
          <span className="text-muted-foreground font-normal">(Optional)</span>
        </Label>
        <Textarea
          id="appt-notes"
          placeholder="Any special requests, medical history relevant to this appointment, or questions for the doctor..."
          value={notes}
          onChange={(e) => onNotesChange(e.target.value)}
          className="rounded-xl resize-none min-h-[100px]"
          data-ocid="appointment-notes-textarea"
        />
      </div>

      {/* Confirm button */}
      <Button
        onClick={onSubmit}
        disabled={isPending}
        size="lg"
        className="w-full rounded-xl font-semibold text-base gap-2 shadow-medical"
        data-ocid="confirm-appointment-btn"
      >
        {isPending ? (
          <>
            <span className="animate-pulse">Submitting…</span>
          </>
        ) : (
          <>
            <CalendarCheck className="w-5 h-5" />
            Confirm Appointment
          </>
        )}
      </Button>
    </div>
  );
}

