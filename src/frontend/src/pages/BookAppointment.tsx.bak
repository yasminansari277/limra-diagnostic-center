      )}
      <p className="text-muted-foreground text-sm mb-6 leading-relaxed max-w-sm mx-auto">
        Our admin will review your request and confirm within{" "}
        <strong className="text-foreground">24 hours</strong>. You can track the
        status in your patient dashboard.
      </p>

      {/* Summary */}
      <div className="bg-secondary/60 rounded-2xl border border-border text-left mb-6 overflow-hidden max-w-sm mx-auto">
        {[
          { label: "Service", value: state.selectedService?.name ?? "—" },
          { label: "Doctor", value: state.selectedDoctor?.name ?? "—" },
          { label: "Date", value: state.preferredDate },
          { label: "Time", value: state.preferredTime },
        ].map((row, i, arr) => (
          <div
            key={row.label}
            className={`flex items-center justify-between px-5 py-3 ${
              i < arr.length - 1 ? "border-b border-border" : ""
            }`}
          >
            <span className="text-xs text-muted-foreground">{row.label}</span>
            <span className="text-xs font-semibold text-foreground">
              {row.value}
            </span>
          </div>
        ))}
      </div>

      {/* Next steps note */}
      <div className="flex items-start gap-2.5 p-3.5 bg-primary/6 rounded-xl border border-primary/15 text-xs text-muted-foreground text-left mb-8 max-w-sm mx-auto">
        <Clock className="w-4 h-4 text-primary flex-shrink-0 mt-0.5" />
        <span>
          <strong className="text-foreground">Next Steps:</strong> Admin will
          approve or reschedule within 24 hrs. Visit your dashboard to track
          status and view any admin notes.
        </span>
      </div>

      {/* Actions */}
      <div className="flex flex-col sm:flex-row items-center justify-center gap-3">
        <Link to="/patient-dashboard">
          <Button
            size="lg"
            className="rounded-xl gap-2 font-semibold"
            data-ocid="go-to-dashboard-btn"
          >
            <User className="w-4 h-4" />
            Go to Dashboard
          </Button>
        </Link>
        <Button
          variant="outline"
          size="lg"
          onClick={onBookAnother}
          className="rounded-xl gap-2"
          data-ocid="book-another-btn"
        >
          <ArrowRight className="w-4 h-4" />
          Book Another
        </Button>
      </div>
    </div>
  );
}

// ─── Main Component ───────────────────────────────────────────────────────────

export default function BookAppointment() {
  const { identity, login } = useInternetIdentity();
  const { data: services, isLoading: servicesLoading } = useGetAllServices();
  const { data: doctors, isLoading: doctorsLoading } = useGetAllDoctors();
  const submitAppointment = useSubmitAppointmentRequest();

  const [step, setStep] = useState(1);
  const [submitted, setSubmitted] = useState(false);
  const [submittedId, setSubmittedId] = useState<bigint | null>(null);

  const [wizardState, setWizardState] = useState<WizardState>({
    selectedService: null,
    selectedDoctor: null,
    preferredDate: "",
    preferredTime: "",
    notes: "",
  });

  const update = (patch: Partial<WizardState>) =>
    setWizardState((prev) => ({ ...prev, ...patch }));

  const handleNext = () => {
    if (step === 1 && !wizardState.selectedService) {
      toast.error("Please select a service to continue.");
      return;
    }
    if (step === 2 && !wizardState.selectedDoctor) {
      toast.error("Please choose a doctor to continue.");
      return;
    }
    if (step === 3) {
      if (!wizardState.preferredDate) {
        toast.error("Please select a preferred date.");
        return;
      }
      if (!wizardState.preferredTime) {
        toast.error("Please choose a time slot.");
        return;
      }
    }
    setStep((s) => s + 1);
  };

  const handleBack = () => setStep((s) => Math.max(1, s - 1));

  const handleSubmit = async () => {
    if (!identity) return;
    try {
      const result = await submitAppointment.mutateAsync({
        doctorId: wizardState.selectedDoctor?.name ?? "",
        serviceId: wizardState.selectedService?.name ?? "",
        requestedDate: wizardState.preferredDate,
        requestedTimeSlot: wizardState.preferredTime,
        patientName: "",
        patientPhone: "",
        patientAddress: "",
      });
      // result may be bigint appointment ID or an object with id
      if (typeof result === "bigint") setSubmittedId(result);
      setSubmitted(true);
    } catch (_err) {
      toast.error("Failed to submit appointment. Please try again.");
    }
  };

  const handleBookAnother = () => {
    setStep(1);
    setSubmitted(false);
    setSubmittedId(null);
    setWizardState({
      selectedService: null,
      selectedDoctor: null,
      preferredDate: "",
      preferredTime: "",
      notes: "",
    });
  };

  // Not logged in
  if (!identity) {
    return <LoginGate onLogin={login} />;
  }

  return (
    <div className="min-h-screen bg-background py-12">
      <div className="container mx-auto px-4 max-w-2xl">
        {/* Page header */}
        {!submitted && (
          <div className="text-center mb-10">
            <Badge className="mb-3 bg-primary/10 text-primary border-primary/20 rounded-full px-4">
              Book Appointment
            </Badge>
            <h1 className="font-display text-3xl md:text-4xl font-bold text-foreground mb-2">
              Schedule Your Visit
            </h1>
            <p className="text-muted-foreground">
              Complete 4 quick steps to request your appointment.
            </p>
          </div>
        )}

        {/* Step indicator */}
        {!submitted && <StepIndicator current={step} />}

        {/* Card */}
        <div className="medical-card p-7 md:p-10">
          {/* Success screen */}
          {submitted ? (
            <SuccessScreen
              appointmentId={submittedId}
              state={wizardState}
              onBookAnother={handleBookAnother}
            />
          ) : (
            <>
              {/* Step content */}
              {step === 1 && (
                <StepSelectService
                  services={services}
                  isLoading={servicesLoading}
                  selected={wizardState.selectedService}
                  onSelect={(s) => update({ selectedService: s })}
                />
              )}
              {step === 2 && (
                <StepChooseDoctor
                  doctors={doctors}
                  isLoading={doctorsLoading}
                  selected={wizardState.selectedDoctor}
                  onSelect={(d) =>
                    update({ selectedDoctor: d, preferredTime: "" })
                  }
                />
              )}
              {step === 3 && (
                <StepDateTime
                  doctor={wizardState.selectedDoctor}
                  date={wizardState.preferredDate}
                  time={wizardState.preferredTime}
                  onDateChange={(d) =>
                    update({ preferredDate: d, preferredTime: "" })
                  }
                  onTimeChange={(t) => update({ preferredTime: t })}
                />
              )}
              {step === 4 && (
                <StepConfirm
                  state={wizardState}
                  notes={wizardState.notes}
                  onNotesChange={(v) => update({ notes: v })}
                  onSubmit={handleSubmit}
                  isPending={submitAppointment.isPending}
                />
              )}

              {/* Navigation */}
              <div className="flex items-center justify-between mt-8 pt-6 border-t border-border">
                {step > 1 ? (
                  <Button
                    variant="outline"
                    onClick={handleBack}
                    disabled={submitAppointment.isPending}
                    className="rounded-xl gap-1.5"
                    data-ocid="wizard-back-btn"
                  >
                    <ChevronLeft className="w-4 h-4" />
                    Back
                  </Button>
                ) : (
                  <div />
                )}

                {step < 4 && (
                  <Button
                    onClick={handleNext}
                    className="rounded-xl gap-1.5"
                    data-ocid="wizard-next-btn"
                  >
                    Next
                    <ChevronRight className="w-4 h-4" />
                  </Button>
                )}
              </div>
            </>
          )}
        </div>

        {/* Progress text */}
        {!submitted && (
          <p className="text-center text-xs text-muted-foreground mt-5">
            Step {step} of {STEPS.length} —{" "}
            <span className="text-primary font-medium">
              {STEPS[step - 1]?.label}
            </span>
          </p>
        )}
      </div>
    </div>
  );
}
